# ============================================================
# RFP Bid Management System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Application ----
APP_NAME="RFP Bid Management System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ---- Database (PostgreSQL) ----
# Use postgresql+asyncpg:// for async driver
DATABASE_URL=postgresql+asyncpg://rfpuser:rfppassword@localhost:5432/rfpdb

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- ChromaDB ----
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- Cohere ----
COHERE_API_KEY=your-cohere-api-key-here

# ---- AI Provider Selection ----
# Options: claude | openai
EXTRACTOR_PROVIDER=claude
DRAFTER_PROVIDER=claude
SCORER_PROVIDER=claude

# ---- AI Model Names ----
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
COHERE_RERANK_MODEL=rerank-english-v3.0

# ---- AWS S3 (optional — set USE_LOCAL_STORAGE=false to enable) ----
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/tmp/rfp_uploads
S3_BUCKET=rfp-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ---- CORS ----
# Comma-separated list of allowed origins (list format in env: JSON array)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- RAG Settings ----
RAG_TOP_K=10
RAG_RERANK_TOP_N=3
RAG_PASS_THRESHOLD=0.75
RAG_PARTIAL_THRESHOLD=0.40

# ---- Proposal Settings ----
PROPOSAL_TARGET_WORDS=500

# ---- Win Score ----
WIN_SCORE_GO_THRESHOLD=65

# ---- Cost Tracking ----
COST_TRACKING_ENABLED=true
CLAUDE_INPUT_COST_PER_1K=0.003
CLAUDE_OUTPUT_COST_PER_1K=0.015
OPENAI_INPUT_COST_PER_1K=0.005
OPENAI_OUTPUT_COST_PER_1K=0.015
EMBEDDING_COST_PER_1K=0.00002

# ---- Access Token ----
ACCESS_TOKEN_EXPIRE_MINUTES=1440
